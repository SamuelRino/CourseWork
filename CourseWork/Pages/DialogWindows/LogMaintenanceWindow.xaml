<Window x:Class="CourseWork.Pages.DialogWindows.LogMaintenanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CourseWork.Pages.DialogWindows"
        mc:Ignorable="d"
        Title="" Height="480" Width="400" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="tbTitle" Text="Запись об обслуживании" VerticalAlignment="Center" FontSize="20" Grid.ColumnSpan="2" Foreground="DodgerBlue" Margin="10"/>

        <StackPanel Grid.Row="1" Margin="5">
            <Label Content="Торговый автомат *"/>
            <ComboBox x:Name="cbMachine" Height="30"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="5">
            <Label Content="Сотрудник (Техник) *"/>
            <ComboBox x:Name="cbEmployee" Height="30"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="5">
            <Label Content="Описание работ *"/>
            <TextBox x:Name="tbDescription" Height="50" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="5">
            <Label Content="Стоимость материалов (₽)"/>
            <TextBox x:Name="tbCost" Height="30" Text="0"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="10">
            <Button x:Name="btnExecute" Foreground="White" Background="DodgerBlue" Content="Сохранить" VerticalAlignment="Center" Padding="5" Click="btnExecute_Click"/>
            <Button x:Name="btnCancel" Content="Отменить" VerticalAlignment="Center" Padding="5" Margin="10,0,0,0" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>