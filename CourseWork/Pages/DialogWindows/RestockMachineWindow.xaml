<Window x:Class="CourseWork.Pages.DialogWindows.RestockMachineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CourseWork.Pages.DialogWindows"
        mc:Ignorable="d"
        Title="" Height="380" Width="350" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="tbTitle" Text="Пополнение торгового автомата" VerticalAlignment="Center" FontSize="20" Grid.ColumnSpan="2" Foreground="DodgerBlue" Margin="10"/>

        <StackPanel Grid.Row="1" Margin="5">
            <Label Content="Сотрудник *"/>
            <ComboBox x:Name="cbEmployee" Height="30" SelectedItem="{Binding Path=Employee}"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="5">
            <Label Content="Продукт *"/>
            <ComboBox x:Name="cbProduct" Height="30" SelectedItem="{Binding Path=Product}"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="5">
            <Label Content="Количество *"/>
            <TextBox x:Name="tbCount" Height="30" Text="{Binding QuantityAdded}"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="10">
            <Button x:Name="btnExecute" Foreground="White" Background="DodgerBlue" Content="Выполнить" VerticalAlignment="Center" Padding="5" Click="btnExecute_Click"/>
            <Button x:Name="btnCancel" Content="Отменить" VerticalAlignment="Center" Padding="5" Margin="10,0,0,0" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
