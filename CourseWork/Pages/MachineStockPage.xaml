<Page x:Class="CourseWork.Pages.MachineStockPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CourseWork.Pages"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
            Title="Торговые автоматы">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Наполнение торговых автоматов" FontSize="24" FontWeight="Bold" Margin="10"/>

        <ListView x:Name="lvMachines" Grid.Row="1">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderThickness="0,0,0,1" BorderBrush="LightGray">
                        <Grid Margin="5" Width="2000">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding Machine.SerialNumber}" Grid.Column="0" VerticalAlignment="Center"/>

                            <ItemsControl ItemsSource="{Binding Data}" Grid.Column="1" VerticalAlignment="Center">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding Product.Name}" Grid.Column="0"/>
                                            <TextBlock Text="{Binding Quantity, StringFormat='Кол-во: {0}'}" Grid.Column="1"/>
                                            <TextBlock Text="{Binding MinLevel, StringFormat='Мин. кол-во: {0}'}" Grid.Column="2"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left" Orientation="Horizontal">
                                <Button x:Name="btnAddProduct" Click="btnAddProduct_Click" Margin="3" Width="25" Padding="3">
                                    <materialDesign:PackIcon Kind="Add" VerticalAlignment="Center"/>
                                </Button>

                                <Button x:Name="btnRestock" Click="btnRestock_Click" Margin="3" Width="25" Padding="3">
                                    <materialDesign:PackIcon Kind="ArchiveArrowDownOutline" VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
