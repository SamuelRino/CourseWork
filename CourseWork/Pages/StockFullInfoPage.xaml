<Page x:Class="CourseWork.Pages.StockFullInfoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CourseWork.Pages"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="1200"
      Title="Отчёт: Наполнение по автоматам">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="10">
            <TextBlock Text="Отчёт: Полная информация по наполнению" FontSize="24" FontWeight="Bold"/>
            <Button x:Name="btnRefresh" Content="Обновить" Margin="20,0,0,0" Width="120" Click="btnRefresh_Click"/>
        </StackPanel>

        <ListView x:Name="lvStockFullInfo" Grid.Row="1">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Серийный номер" Width="150" DisplayMemberBinding="{Binding SerialNumber}"/>
                    <GridViewColumn Header="Адрес" Width="250" DisplayMemberBinding="{Binding Address}"/>
                    <GridViewColumn Header="Товар" Width="200" DisplayMemberBinding="{Binding ProductName}"/>
                    <GridViewColumn Header="Категория" Width="150" DisplayMemberBinding="{Binding Category}"/>
                    <GridViewColumn Header="В наличии" Width="100" DisplayMemberBinding="{Binding Quantity}"/>
                    <GridViewColumn Header="Мин. остаток" Width="100" DisplayMemberBinding="{Binding MinLevel}"/>
                    <GridViewColumn Header="Статус" Width="120" DisplayMemberBinding="{Binding StockStatus}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>